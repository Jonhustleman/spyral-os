# SPYRAL OS — Local Development Environment Variables
# Copy this to .env.local and fill in the values.

# Authentication
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=

# In development, you can skip AUTH_SECRET — a random dev secret will be generated.
# Tokens will be invalidated on server restart without a persistent secret.
