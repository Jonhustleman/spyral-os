# SPYRAL OS — Local Development Environment Variables
# Copy this to .env.local and fill in the values.
# .env.local is gitignored — your secrets stay local.

# Authentication
# IMPORTANT: In production (Vercel), set AUTH_SECRET in the Vercel project dashboard:
#   Settings → Environment Variables → AUTH_SECRET
# Generate a secret using:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=

# If AUTH_SECRET is not set:
#   - In production: a stable fallback is derived from VERCEL_GIT_REPO_SLUG + OWNER
#   - In development: a deterministic secret is derived from the machine hostname
#   Both ensure tokens survive server restarts and redeploys.
#   For maximum security, always set AUTH_SECRET explicitly.
